{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "jsx": "preserve",
    "types": ["vite/client"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "vite.config.ts"]
}
